    "rolldown": {
      "optional": true
    },
    "rollup": {
      "optional": true
    },
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsdown",
    "prepack": "node ../../scripts/pack-meta.mjs",
    "postpack": "node ../../scripts/pack-meta.mjs --cleanup",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  }
